# ── Neuron OS — Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your keys:
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (Mac/Linux)
#
# The .env file is auto-loaded from the project root on startup.
# Variables already set in your shell are NOT overridden.
# ──────────────────────────────────────────────────────────────────────

# ── AI Provider Keys (choose at least one) ──────────────────────────
# Uncomment and fill in your key for your preferred provider:
#ANTHROPIC_API_KEY=sk-ant-...            # https://console.anthropic.com/
#OPENAI_API_KEY=sk-...                    # https://platform.openai.com/api-keys
#OPENROUTER_API_KEY=sk-or-v1-...          # https://openrouter.ai/keys
#DEEPSEEK_API_KEY=sk-...                  # https://platform.deepseek.com/
#GOOGLE_GENERATIVE_AI_API_KEY=AIza...     # https://aistudio.google.com/
#GROQ_API_KEY=gsk_...                     # https://console.groq.com/keys
#MISTRAL_API_KEY=...                      # https://console.mistral.ai/
#AZURE_OPENAI_API_KEY=...                 # Azure OpenAI
#TOGETHERAI_API_KEY=...                   # https://together.ai
#XAI_API_KEY=...                          # https://x.ai/api
#COHERE_API_KEY=...                       # https://dashboard.cohere.com
#PERPLEXITY_API_KEY=pplx-...              # https://perplexity.ai/settings/api

# Universal fallback (used if no provider-specific key is found)
# AEGIS_AI_API_KEY=sk-...

# ── Provider & Model Selection ──────────────────────────────────────
# Defaults: anthropic / claude-sonnet-4-20250514
# AEGIS_AI_PROVIDER=openrouter
# AEGIS_AI_MODEL=openrouter/free

# Custom base URL (for Ollama, proxies, or custom endpoints)
# AEGIS_AI_BASE_URL=http://localhost:11434/v1

# AI fallbacks (tried on failure)
# AEGIS_AI_FALLBACKS=openai:gpt-4o-mini,deepseek:deepseek-chat

# ── Telegram Bot (for mobile access via phone) ─────────────────────
# Get token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# ── Other Platforms ────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...

# ── Web Search ─────────────────────────────────────────────────────
# FIRECRAWL_API_KEY=...       # https://www.firecrawl.dev/
# TAVILY_API_KEY=...           # https://tavily.com/
# SERPAPI_API_KEY=...          # https://serpapi.com/

# ── OpenTelemetry / Langfuse Tracing ─────────────────────────────
# Get keys from https://cloud.langfuse.com (Settings → Project → API Keys)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com   # Change for self-hosted

# ── System ─────────────────────────────────────────────────────────
# AEGIS_LOG_LEVEL=info
