# =============================================================================
# Aegis — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is auto-loaded from the project root on startup.
# Variables already set in your shell environment are NOT overridden.

# ── AI Provider & Model ────────────────────────────────────────────────────
AEGIS_AI_PROVIDER=openrouter          # openai | anthropic | deepseek | groq | gemini | mistral | openrouter | ollama | custom
AEGIS_AI_MODEL=openrouter/auto        # Model name (default varies by provider)
AEGIS_AI_API_KEY=                     # Universal AI API key (fallback for all providers)

# Alternative env var names (checked in order by chat and agent commands)
# AI_PROVIDER=
# AI_MODEL=
# DEFAULT_AI_PROVIDER=
# DEFAULT_AI_MODEL=

# Custom API base URL (optional)
# AEGIS_AI_BASE_URL=
# AI_BASE_URL=

# Generation settings
# AEGIS_TEMPERATURE=0.7
# AEGIS_MAX_TOKENS=4096
# AI_TEMPERATURE=0.7
# AI_MAX_TOKENS=8192
# AEGIS_MAX_TURNS=20

# ── Provider-Specific API Keys ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-         # https://openrouter.ai/keys
ANTHROPIC_API_KEY=                     # https://console.anthropic.com/
OPENAI_API_KEY=                        # https://platform.openai.com/api-keys
DEEPSEEK_API_KEY=                      # https://platform.deepseek.com/
GROQ_API_KEY=                          # https://console.groq.com/keys
GOOGLE_GENERATIVE_AI_API_KEY=          # https://aistudio.google.com/app/apikey
MISTRAL_API_KEY=                       # https://console.mistral.ai/api-keys/

# AI fallbacks — comma-separated list of provider:model
# AEGIS_AI_FALLBACKS=openai:gpt-4o,anthropic:claude-sonnet-4-20250514

# ── Agent Configuration ────────────────────────────────────────────────────
# AEGIS_AGENT_NAME=my-agent
# AEGIS_AGENT_ID=auto
# AEGIS_AGENT_TYPE=assistant
# AEGIS_SKILL_MAPPINGS=

# ── Skills Registry ────────────────────────────────────────────────────────
# Self-host: https://github.com/mastra-ai/skills-api
# SKILLS_API_URL=http://localhost:3456/api
# SKILLS_DIRS=./extra-skills;/path/to/more-skills

# ── Memory (AgentMemory server) ────────────────────────────────────────────
# AGENTMEMORY_URL=http://localhost:3111
# AGENTMEMORY_SECRET=
# AGENTMEMORY_ENABLED=true

# ── Logging ────────────────────────────────────────────────────────────────
# AEGIS_LOG_LEVEL=info              # debug | info | warn | error
# AEGIS_LOG_FILE=aegis.log
# AEGIS_LOG_MAX_SIZE=10485760      # 10 MB
# AEGIS_LOG_MAX_FILES=5

# ── Telemetry ──────────────────────────────────────────────────────────────
# AEGIS_TELEMETRY=false             # false | true | 0 | 1
# AEGIS_TELEMETRY_ENDPOINT=

# ── Security / Vault ───────────────────────────────────────────────────────
# AEGIS_VAULT_KEY=                   # Encryption key for credential vault

# ── Sandbox ────────────────────────────────────────────────────────────────
# AEGIS_SANDBOX=none                # none | process | docker

# ── Web Search Tools ───────────────────────────────────────────────────────
# TAVILY_API_KEY=                    # https://tavily.com/
# SERPAPI_API_KEY=                   # https://serpapi.com/
# FIRECRAWL_API_KEY=                 # https://www.firecrawl.dev/

# ── API Server ─────────────────────────────────────────────────────────────
# AEGIS_API_PORT=7171
# AEGIS_API_HOST=localhost

# ── Telegram Bot ───────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── Harness ────────────────────────────────────────────────────────────────
# HARNESS_MODEL=claude-sonnet-4-20250514
